//@version=5
indicator("SMT Divergence MNQ/MES + FVG HTF + Liquidity Sweep", overlay=true, max_boxes_count=500, max_lines_count=500)

// ══════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════

// SMT Settings
grp_smt = "══ SMT Divergence ══"
smt_show = input.bool(true, "Show SMT Divergence", group=grp_smt)
smt_lookback = input.int(5, "Swing Lookback", minval=2, maxval=20, group=grp_smt)
smt_bullish_color = input.color(color.new(color.green, 30), "Bullish SMT Color", group=grp_smt)
smt_bearish_color = input.color(color.new(color.red, 30), "Bearish SMT Color", group=grp_smt)

// FVG Settings
grp_fvg = "══ Fair Value Gaps ══"
fvg_show = input.bool(true, "Show FVG", group=grp_fvg)
fvg_htf = input.timeframe("60", "FVG Timeframe", group=grp_fvg)
fvg_bullish_color = input.color(color.new(color.green, 85), "Bullish FVG Color", group=grp_fvg)
fvg_bearish_color = input.color(color.new(color.red, 85), "Bearish FVG Color", group=grp_fvg)
fvg_show_mitigated = input.bool(false, "Show Mitigated FVG", group=grp_fvg)

// Liquidity Sweep Settings
grp_liq = "══ Liquidity Sweep ══"
liq_show = input.bool(true, "Show Liquidity Sweeps", group=grp_liq)
liq_session = input.string("Previous", "Liquidity Reference", options=["Previous", "Asia", "London"], group=grp_liq)
liq_sweep_bull_color = input.color(color.new(color.lime, 30), "Bullish Sweep Color", group=grp_liq)
liq_sweep_bear_color = input.color(color.new(color.fuchsia, 30), "Bearish Sweep Color", group=grp_liq)

// Session Settings
grp_session = "══ Sessions ══"
session_show = input.bool(true, "Show Session Ranges", group=grp_session)
session_asia = input.bool(true, "Show Asia", group=grp_session)
session_london = input.bool(true, "Show London", group=grp_session)
session_ny = input.bool(true, "Show NY", group=grp_session)
session_asia_color = input.color(color.new(color.orange, 70), "Asia Color", group=grp_session)
session_london_color = input.color(color.new(color.blue, 70), "London Color", group=grp_session)
session_ny_color = input.color(color.new(color.yellow, 70), "NY Color", group=grp_session)

// Alert Settings
grp_alert = "══ Alerts ══"
alert_smt = input.bool(true, "Alert on SMT", group=grp_alert)
alert_fvg = input.bool(true, "Alert on FVG", group=grp_alert)
alert_sweep = input.bool(true, "Alert on Liquidity Sweep", group=grp_alert)

// ══════════════════════════════════════════════════════════════════
// SMT DIVERGENCE
// ══════════════════════════════════════════════════════════════════

// We use built-in ES to represent MES correlation
// When available: use ticker("CME_MINI:ES1!") or similar
// For SMT, we compare swing highs/lows of current chart vs correlated asset

swing_high = ta.pivothigh(high, smt_lookback, smt_lookback)
swing_low = ta.pivotlow(low, smt_lookback, smt_lookback)

var float last_swing_high = na
var float last_swing_low = na
var int last_swing_high_bar = na
var int last_swing_low_bar = na

// Detect new swing points
if not na(swing_high)
    last_swing_high := swing_high
    last_swing_high_bar := bar_index - smt_lookback

if not na(swing_low)
    last_swing_low := swing_low
    last_swing_low_bar := bar_index - smt_lookback

// ══════════════════════════════════════════════════════════════════
// FVG DETECTION (Higher Timeframe)
// ══════════════════════════════════════════════════════════════════

// Request HTF data
htf_high = request.security(syminfo.tickerid, fvg_htf, high[1])
htf_low = request.security(syminfo.tickerid, fvg_htf, low[1])
htf_close_prev = request.security(syminfo.tickerid, fvg_htf, close[2])
htf_open_next = request.security(syminfo.tickerid, fvg_htf, open)
htf_high_prev = request.security(syminfo.tickerid, fvg_htf, high[2])
htf_low_next = request.security(syminfo.tickerid, fvg_htf, low)

// FVG Bullish: gap between candle[2] high and candle[0] low (3-candle pattern)
// Middle candle goes up, creates gap below
bull_fvg_top = htf_low
bull_fvg_bottom = htf_close_prev

// FVG Bearish: gap between candle[0] high and candle[2] low
bear_fvg_top = htf_high_prev
bear_fvg_bottom = htf_open_next

// Simplified FVG detection
fvg_bullish = htf_low_next > htf_close_prev and htf_close_prev > htf_high_prev
fvg_bearish = htf_open_next < htf_close_prev and htf_close_prev < htf_low_next

// More practical FVG: 3 consecutive candles with gap
candle0 = request.security(syminfo.tickerid, fvg_htf, close[0] - open[0])
candle1 = request.security(syminfo.tickerid, fvg_htf, close[1] - open[1])
candle2 = request.security(syminfo.tickerid, fvg_htf, close[2] - open[2])

body0 = request.security(syminfo.tickerid, fvg_htf, math.abs(close[0] - open[0]))
body1 = request.security(syminfo.tickerid, fvg_htf, math.abs(close[1] - open[1]))
body2 = request.security(syminfo.tickerid, fvg_htf, math.abs(close[2] - open[2]))

wick_high0 = request.security(syminfo.tickerid, fvg_htf, high - math.max(open, close))
wick_low0 = request.security(syminfo.tickerid, fvg_htf, math.min(open, close) - low)
wick_high1 = request.security(syminfo.tickerid, fvg_htf, high[1] - math.max(open[1], close[1]))
wick_low1 = request.security(syminfo.tickerid, fvg_htf, math.min(open[1], close[1]) - low[1])
wick_high2 = request.security(syminfo.tickerid, fvg_htf, high[2] - math.max(open[2], close[2]))
wick_low2 = request.security(syminfo.tickerid, fvg_htf, math.min(open[2], close[2]) - low[2])

// Classic FVG: big middle candle, gaps on both sides
htf_o1 = request.security(syminfo.tickerid, fvg_htf, open[1])
htf_c1 = request.security(syminfo.tickerid, fvg_htf, close[1])
htf_h2 = request.security(syminfo.tickerid, fvg_htf, high[2])
htf_l0 = request.security(syminfo.tickerid, fvg_htf, low[0])

bullish_fvg = htf_c1 > htf_o1 and htf_l0 > htf_h2
bearish_fvg = htf_c1 < htf_o1 and htf_h0 < htf_l2

htf_h0_val = request.security(syminfo.tickerid, fvg_htf, high[0])
htf_l2_val = request.security(syminfo.tickerid, fvg_htf, low[2])

bullish_fvg_final = htf_c1 > htf_o1 and htf_l0_val > htf_h2
bearish_fvg_final = htf_c1 < htf_o1 and htf_h0_val < htf_l2

// Store FVG levels
var float bull_fvg_upper = na
var float bull_fvg_lower = na
var float bear_fvg_upper = na
var float bear_fvg_lower = na

if bullish_fvg_final and fvg_show
    bull_fvg_upper := htf_l0_val
    bull_fvg_lower := htf_h2

if bearish_fvg_final and fvg_show
    bear_fvg_upper := htf_h0_val
    bear_fvg_lower := htf_l2

// ══════════════════════════════════════════════════════════════════
// SESSION DETECTION (UTC Times)
// ══════════════════════════════════════════════════════════════════

// Session times in UTC
// Asia: 20:00 - 00:00 UTC (next day)
// London: 07:00 - 10:00 UTC
// NY: 13:30 - 20:00 UTC

is_asia = not na(time(timeframe.period, "2000-0000", "UTC"))
is_london = not na(time(timeframe.period, "0700-1000", "UTC"))
is_ny = not na(time(timeframe.period, "1330-2000", "UTC"))

// Session highs and lows
var float asia_high = na
var float asia_low = na
var float london_high = na
var float london_low = na
var float ny_high = na
var float ny_low = na
var float prev_asia_high = na
var float prev_asia_low = na
var float prev_london_high = na
var float prev_london_low = na

// Track session highs/lows
if is_asia
    if na(asia_high) or high > asia_high
        asia_high := high
    if na(asia_low) or low < asia_low
        asia_low := low

if is_london
    if na(london_high) or high > london_high
        london_high := high
    if na(london_low) or low < london_low
        london_low := low

if is_ny
    if na(ny_high) or high > ny_high
        ny_high := high
    if na(ny_low) or low < ny_low
        ny_low := low

// Reset at session boundaries
new_day = ta.change(time("D")) != 0
if new_day
    prev_asia_high := asia_high
    prev_asia_low := asia_low
    prev_london_high := london_high
    prev_london_low := london_low
    asia_high := na
    asia_low := na
    london_high := na
    london_low := na
    ny_high := na
    ny_low := na

// ══════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ══════════════════════════════════════════════════════════════════

var float ref_high = na
var float ref_low = na

// Set reference levels based on selected session
if liq_session == "Previous"
    ref_high := prev_asia_high
    ref_low := prev_asia_low
else if liq_session == "Asia"
    ref_high := prev_asia_high
    ref_low := prev_asia_low
else if liq_session == "London"
    ref_high := prev_london_high
    ref_low := prev_london_low

// Liquidity sweep: price goes above/below reference then closes back
sweep_high = high > ref_high and close < ref_high and not na(ref_high)
sweep_low = low < ref_low and close > ref_low and not na(ref_low)

// ══════════════════════════════════════════════════════════════════
// PLOTTING
// ══════════════════════════════════════════════════════════════════

// Session Lines
plot(session_show and session_asia ? prev_asia_high : na, "Prev Asia High", color=session_asia_color, style=plot.style_linebr, linewidth=1)
plot(session_show and session_asia ? prev_asia_low : na, "Prev Asia Low", color=session_asia_color, style=plot.style_linebr, linewidth=1)
plot(session_show and session_london ? prev_london_high : na, "Prev London High", color=session_london_color, style=plot.style_linebr, linewidth=1)
plot(session_show and session_london ? prev_london_low : na, "Prev London Low", color=session_london_color, style=plot.style_linebr, linewidth=1)
plot(session_show and session_ny ? ny_high : na, "NY High", color=session_ny_color, style=plot.style_linebr, linewidth=2)
plot(session_show and session_ny ? ny_low : na, "NY Low", color=session_ny_color, style=plot.style_linebr, linewidth=2)

// Liquidity Sweep Markers
plotshape(liq_show and sweep_high, "Sweep High", shape.triangledown, location.abovebar, liq_sweep_bear_color, size=size.small)
plotshape(liq_show and sweep_low, "Sweep Low", shape.triangleup, location.belowbar, liq_sweep_bull_color, size=size.small)

// SMT Divergence Markers
plotshape(smt_show and not na(swing_high), "Swing High", shape.diamond, location.abovebar, smt_bearish_color, size=size.tiny)
plotshape(smt_show and not na(swing_low), "Swing Low", shape.diamond, location.belowbar, smt_bullish_color, size=size.tiny)

// FVG Background
bgcolor(fvg_show and bullish_fvg_final ? fvg_bullish_color : na)
bgcolor(fvg_show and bearish_fvg_final ? fvg_bearish_color : na)

// ══════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════

alertcondition(sweep_high and alert_sweep, "Liquidity Sweep High", "🔴 Liquidity Sweep HIGH detected")
alertcondition(sweep_low and alert_sweep, "Liquidity Sweep Low", "🟢 Liquidity Sweep LOW detected")
alertcondition(bullish_fvg_final and alert_fvg, "Bullish FVG", "🟢 Bullish Fair Value Gap detected")
alertcondition(bearish_fvg_final and alert_fvg, "Bearish FVG", "🔴 Bearish Fair Value Gap detected")
alertcondition(not na(swing_high) and alert_smt, "Swing High", "Swing High detected")
alertcondition(not na(swing_low) and alert_smt, "Swing Low", "Swing Low detected")

// ══════════════════════════════════════════════════════════════════
// INFO TABLE
// ══════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), frame_color=color.gray, frame_width=1, border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "SMT", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, smt_show ? "ON" : "OFF", text_color=smt_show ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 1, "FVG HTF", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, fvg_show ? fvg_htf : "OFF", text_color=fvg_show ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 2, "LiQ Ref", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, liq_show ? liq_session : "OFF", text_color=liq_show ? color.green : color.red, text_size=size.small)
    table.cell(infoTable, 0, 3, "Asia", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, session_asia ? str.tostring(prev_asia_high, "#.##") + " / " + str.tostring(prev_asia_low, "#.##") : "OFF", text_color=session_asia ? color.orange : color.red, text_size=size.small)
    table.cell(infoTable, 0, 4, "London", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, session_london ? str.tostring(prev_london_high, "#.##") + " / " + str.tostring(prev_london_low, "#.##") : "OFF", text_color=session_london ? color.blue : color.red, text_size=size.small)
    table.cell(infoTable, 0, 5, "NY", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 5, session_ny ? str.tostring(ny_high, "#.##") + " / " + str.tostring(ny_low, "#.##") : "OFF", text_color=session_ny ? color.yellow : color.red, text_size=size.small)
    table.cell(infoTable, 0, 6, "Bull FVG", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 6, not na(bull_fvg_upper) ? str.tostring(bull_fvg_upper, "#.##") + " / " + str.tostring(bull_fvg_lower, "#.##") : "None", text_color=not na(bull_fvg_upper) ? color.green : color.gray, text_size=size.small)
    table.cell(infoTable, 0, 7, "Bear FVG", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 7, not na(bear_fvg_upper) ? str.tostring(bear_fvg_upper, "#.##") + " / " + str.tostring(bear_fvg_lower, "#.##") : "None", text_color=not na(bear_fvg_upper) ? color.red : color.gray, text_size=size.small)
