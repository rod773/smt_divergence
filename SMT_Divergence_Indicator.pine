//@version=5
indicator("SMT Divergence & Manipulation X", overlay=true, max_bars_back=500)

// ─── Inputs ─────────────────────────────────────────────────────────────────
showFvg        = input.bool(true,  "Show Fair Value Gaps")
showIfvg       = input.bool(true,  "Show Inverse FVGs")
showSmt        = input.bool(true,  "Show SMT Divergence")
showLiquidity  = input.bool(true,  "Show Draws on Liquidity")
showSession    = input.bool(true,  "Show NY Session")

fvgTF          = input.string("15", "FVG Timeframe", options=["5","15","30","60","240"])
smtSymbol      = input.symbol("ES1!", "SMT Comparison Symbol")
liqLookback    = input.int(50, "Liquidity Lookback", minval=10, maxval=200)

colorBullFvg   = input.color(color.new(#00ff88, 75), "Bullish FVG")
colorBearFvg   = input.color(color.new(#ff4444, 75), "Bearish FVG")
colorSmtBull   = input.color(color.new(#2196F3, 0),  "Bullish SMT Label")
colorSmtBear   = input.color(color.new(#FF9800, 0),  "Bearish SMT Label")
colorLiq       = input.color(color.new(#9C27B0, 0),  "Liquidity Label")

// ─── NY Session Marker ──────────────────────────────────────────────────────
if showSession
    nYOpen  = timestamp("America/New_York", year, month, dayofmonth, 9, 30)
    nYClose = timestamp("America/New_York", year, month, dayofmonth, 16, 0)
    inSession = time >= nYOpen and time < nYClose
    justOpened = time >= nYOpen and time < nYOpen + 120000
    if justOpened
        label.new(bar_index, high, " NY Open\n 9:30 ET", color=color.new(#607D8B, 20),
         style=label.style_label_lower_left, textcolor=color.white, size=size.normal,
         textfont=font.family_monospace)

// ─── HTF FVG Data ───────────────────────────────────────────────────────────
fvgHigh   = request.security(syminfo.tickerid, fvgTF, high)
fvgLow    = request.security(syminfo.tickerid, fvgTF, low)
fvgOpen   = request.security(syminfo.tickerid, fvgTF, open)
fvgClose  = request.security(syminfo.tickerid, fvgTF, close)
fvgHi1    = request.security(syminfo.tickerid, fvgTF, high[1])
fvgLo1    = request.security(syminfo.tickerid, fvgTF, low[1])

bullFvgTop    = fvgLow > fvgHi1 and fvgClose > fvgOpen ? fvgLow : na
bullFvgBot    = fvgLow > fvgHi1 and fvgClose > fvgOpen ? fvgHi1 : na
bearFvgTop    = fvgHigh < fvgLo1 and fvgClose < fvgOpen ? fvgLo1 : na
bearFvgBot    = fvgHigh < fvgLo1 and fvgClose < fvgOpen ? fvgHigh : na

// ─── 1m IFVG Data ───────────────────────────────────────────────────────────
[m1Hi, m1Lo, m1Op, m1Cl] = request.security(syminfo.tickerid, "1", [high, low, open, close])
m1Hi1 = request.security(syminfo.tickerid, "1", high[1])
m1Lo1 = request.security(syminfo.tickerid, "1", low[1])

// Bullish IFVG: bear candle closes below previous low, next candle closes above
bullIfvgCond = m1Cl < m1Op and m1Cl < m1Lo1 and close > open
// Bearish IFVG: bull candle closes above previous high, next candle closes below
bearIfvgCond = m1Cl > m1Op and m1Cl > m1Hi1 and close < open

// ─── SMT Data ───────────────────────────────────────────────────────────────
smtHi  = request.security(smtSymbol, timeframe.period, high)
smtLo  = request.security(smtSymbol, timeframe.period, low)

// Swing low: bar is lower than neighbors
swingLow  = low < low[1] and low <= low[2]
swingHigh = high > high[1] and high >= high[2]

// Bullish SMT: NQ makes higher low, ES makes lower low (same period comparison)
bullSmt = swingLow and low > low[2] and smtLo < smtLo[2]
// Bearish SMT: NQ makes lower high, ES makes higher high
bearSmt = swingHigh and high < high[2] and smtHi > smtHi[2]

// ─── Liquidity Levels ───────────────────────────────────────────────────────
eqHighFound = false
eqLowFound  = false
for i = 3 to liqLookback
    if not eqHighFound and high == high[i] and high > high[1]
        label.new(bar_index[i], high[i], "EQH", color=colorLiq,
         style=label.style_label_down, textcolor=color.white, size=size.tiny,
         textfont=font.family_monospace)
        eqHighFound := true
    if not eqLowFound and low == low[i] and low < low[1]
        label.new(bar_index[i], low[i], "EQL", color=colorLiq,
         style=label.style_label_up, textcolor=color.white, size=size.tiny,
         textfont=font.family_monospace)
        eqLowFound := true

// ─── Plotting ───────────────────────────────────────────────────────────────
// FVG Boxes
plotshape(showFvg and not na(bullFvgTop), title="Bullish FVG Top",  style=shape.triangledown,
 location=location.absolute, color=colorBullFvg, size=size.tiny, y=bullFvgTop)
plotshape(showFvg and not na(bullFvgBot), title="Bullish FVG Bottom", style=shape.triangleup,
 location=location.absolute, color=colorBullFvg, size=size.tiny, y=bullFvgBot)
plotshape(showFvg and not na(bearFvgTop), title="Bearish FVG Top",  style=shape.triangledown,
 location=location.absolute, color=colorBearFvg, size=size.tiny, y=bearFvgTop)
plotshape(showFvg and not na(bearFvgBot), title="Bearish FVG Bottom", style=shape.triangleup,
 location=location.absolute, color=colorBearFvg, size=size.tiny, y=bearFvgBot)

// FVG fill lines
if showFvg
    if not na(bullFvgTop)
        line.new(bar_index, bullFvgTop, bar_index, bullFvgTop, color=colorBullFvg, width=1, style=line.style_solid)
        line.new(bar_index, bullFvgBot, bar_index, bullFvgBot, color=colorBullFvg, width=1, style=line.style_solid)
    if not na(bearFvgTop)
        line.new(bar_index, bearFvgTop, bar_index, bearFvgTop, color=colorBearFvg, width=1, style=line.style_solid)
        line.new(bar_index, bearFvgBot, bar_index, bearFvgBot, color=colorBearFvg, width=1, style=line.style_solid)

// IFVG Labels
if showIfvg and bullIfvgCond
    label.new(bar_index, low, " IFVG ▲", color=color.new(#00E676, 30),
     style=label.style_label_up, textcolor=color.white, size=size.tiny,
     textfont=font.family_monospace)
if showIfvg and bearIfvgCond
    label.new(bar_index, high, " IFVG ▼", color=color.new(#FF1744, 30),
     style=label.style_label_down, textcolor=color.white, size=size.tiny,
     textfont=font.family_monospace)

// SMT Labels
if showSmt and bullSmt
    label.new(bar_index, low, " SMT ▲", color=colorSmtBull,
     style=label.style_label_up, textcolor=color.white, size=size.small,
     textfont=font.family_monospace)
if showSmt and bearSmt
    label.new(bar_index, high, " SMT ▼", color=colorSmtBear,
     style=label.style_label_down, textcolor=color.white, size=size.small,
     textfont=font.family_monospace)

// ─── Alerts ─────────────────────────────────────────────────────────────────
alertcondition(bullSmt, "Bullish SMT Divergence", "{{ticker}}: Bullish SMT divergence")
alertcondition(bearSmt, "Bearish SMT Divergence", "{{ticker}}: Bearish SMT divergence")
alertcondition(bullIfvgCond, "Bullish IFVG", "{{ticker}}: Bullish IFVG entry signal")
alertcondition(bearIfvgCond, "Bearish IFVG", "{{ticker}}: Bearish IFVG entry signal")
