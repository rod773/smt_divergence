//@version=5
indicator("ManipulationX V.6", overlay=true, max_lines_count=300, max_labels_count=300, max_boxes_count=200)

// ─── Settings ────────────────────────────────────────────────────────────────
showFvg15   = input.bool(true,  "Show 15m FVG")
showFvg1h   = input.bool(true,  "Show 1h FVG")
showFvg4h   = input.bool(false, "Show 4h FVG")
showIFVG    = input.bool(true,  "Show iFVGs")
showSmt     = input.bool(true,  "Show SMT Divergence")
smtSymbol   = input.symbol("ES1!", "SMT Symbol")
showDol     = input.bool(true,  "Show DOL Levels")
showSr      = input.bool(true,  "Show S/R Levels")
showKz      = input.bool(true,  "Use Killzones")

cFvgBull = input.color(color.new(#00ff88, 50), "Bullish FVG")
cFvgBear = input.color(color.new(#ff4444, 50), "Bearish FVG")
cSmtBull = input.color(#2196F3, "Bullish SMT")
cSmtBear = input.color(#FF9800, "Bearish SMT")
cDol     = input.color(#9C27B0, "DOL")
cKzNy    = color.new(#546E7A, 60)
cKzLon   = color.new(#455A64, 65)

// ─── Killzones ───────────────────────────────────────────────────────────────
nySess = time(timeframe.period, "0930-1600", "America/New_York")
nyKz = showKz and not na(nySess)
nyStart = showKz and na(nySess[1]) and not na(nySess)
bgcolor(nyKz ? cKzNy : na)
if nyStart
    label.new(bar_index, high, " NY Open ", color=cKzNy, style=label.style_label_lower_left,
     textcolor=color.white, size=size.small)

lonSess = time(timeframe.period, "0300-1200", "America/New_York")
lonKz = showKz and not na(lonSess)
bgcolor(lonKz ? cKzLon : na)

// ─── HTF FVG (time-aligned boxes, drawn once per HTF bar) ────────────────────
fvgData(tf) =>
    [h, l, h2, l2, t] = request.security(syminfo.tickerid, tf, [high, low, high[2], low[2], time])
    bull = l > h2
    bear = h < l2
    fresh = ta.change(t) != 0
    [bull, bear, l, h2, l2, h, t, fresh]

[d15b, d15r, l15, h215, l215, h15, t15, n15] = fvgData("15")
[d1hb, d1hr, l1h, h21h, l21h, h1h, t1h, n1h] = fvgData("60")
[d4hb, d4hr, l4h, h24h, l24h, h4h, t4h, n4h] = fvgData("240")

drawFvgBox(t0, t1, yHi, yLo, c) =>
    box.new(t0, yHi, t1, yLo, xloc=xloc.bar_time, border_color=c, bgcolor=c)
    line.new(t0, yHi, t1, yHi, xloc=xloc.bar_time, color=c)
    line.new(t0, yLo, t1, yLo, xloc=xloc.bar_time, color=c)

if showFvg15 and d15b[1] and n15 and not na(t15[1])
    drawFvgBox(t15[1], t15, l15[1], h215[1], cFvgBull)
if showFvg15 and d15r[1] and n15 and not na(t15[1])
    drawFvgBox(t15[1], t15, l215[1], h15[1], cFvgBear)
if showFvg1h and d1hb[1] and n1h and not na(t1h[1])
    drawFvgBox(t1h[1], t1h, l1h[1], h21h[1], cFvgBull)
if showFvg1h and d1hr[1] and n1h and not na(t1h[1])
    drawFvgBox(t1h[1], t1h, l21h[1], h1h[1], cFvgBear)
if showFvg4h and d4hb[1] and n4h and not na(t4h[1])
    drawFvgBox(t4h[1], t4h, l4h[1], h24h[1], cFvgBull)
if showFvg4h and d4hr[1] and n4h and not na(t4h[1])
    drawFvgBox(t4h[1], t4h, l24h[1], h4h[1], cFvgBear)

// ─── IFVG (1m) ───────────────────────────────────────────────────────────────
[mHi, mLo, mOp, mCl] = request.security(syminfo.tickerid, "1", [high, low, open, close])
mHi1 = request.security(syminfo.tickerid, "1", high[1])
mLo1 = request.security(syminfo.tickerid, "1", low[1])

bIFVG = mCl < mOp and mCl < mLo1 and close > mHi1
sIFVG = mCl > mOp and mCl > mHi1 and close < mLo1

if showIFVG and bIFVG
    label.new(bar_index, low, " IFVG", color=color.new(#00E676, 20),
     style=label.style_label_up, textcolor=color.white, size=size.tiny)
if showIFVG and sIFVG
    label.new(bar_index, high, " IFVG", color=color.new(#FF1744, 20),
     style=label.style_label_down, textcolor=color.white, size=size.tiny)

// ─── SMT Divergence ──────────────────────────────────────────────────────────
nqPl = ta.pivotlow(low, 2, 2)
nqPh = ta.pivothigh(high, 2, 2)
esPl = request.security(smtSymbol, timeframe.period, ta.pivotlow(low, 2, 2))
esPh = request.security(smtSymbol, timeframe.period, ta.pivothigh(high, 2, 2))

var float pNqLo = na; var float pEsLo = na
var float pNqHi = na; var float pEsHi = na
bSMT = false; sSMT = false

if not na(nqPl)
    eLo = ta.valuewhen(not na(esPl), esPl, 0)
    if not na(pNqLo) and not na(eLo) and nqPl > pNqLo and eLo < pEsLo
        bSMT := true
    pNqLo := nqPl
    if not na(eLo); pEsLo := eLo

if not na(nqPh)
    eHi = ta.valuewhen(not na(esPh), esPh, 0)
    if not na(pNqHi) and not na(eHi) and nqPh < pNqHi and eHi > pEsHi
        sSMT := true
    pNqHi := nqPh
    if not na(eHi); pEsHi := eHi

if showSmt and bSMT
    label.new(bar_index, low, " SMT", color=cSmtBull,
     style=label.style_label_up, textcolor=color.white, size=size.small)
if showSmt and sSMT
    label.new(bar_index, high, " SMT", color=cSmtBear,
     style=label.style_label_down, textcolor=color.white, size=size.small)

// ─── DOL Levels ──────────────────────────────────────────────────────────────
if showDol
    if not na(nqPh)
        label.new(bar_index, high, "DOL", color=cDol,
         style=label.style_label_down, textcolor=color.white, size=size.tiny)
    if not na(nqPl)
        label.new(bar_index, low, "DOL", color=cDol,
         style=label.style_label_up, textcolor=color.white, size=size.tiny)

// ─── S/R Levels (pivot-based horizontal lines, max 30) ────────────────────────
var line[] srLines = array.new_line()
drawSrLine(px) =>
    l = line.new(bar_index, px, bar_index+20, px, color=color.new(#FFD600, 30), width=1,
     extend=extend.right)
    array.push(srLines, l)
    if array.size(srLines) > 30
        l2 = array.shift(srLines)
        line.delete(l2)

if showSr
    srHi = ta.pivothigh(high, 3, 3)
    srLo = ta.pivotlow(low, 3, 3)
    if not na(srHi); drawSrLine(srHi)
    if not na(srLo); drawSrLine(srLo)

// ─── Checklist ───────────────────────────────────────────────────────────────
if barstate.islast
    lbl = "1. NY session (9:30am est)\n2. Mark out DOLs/FVGs\n3. Entry model (iFVG)\n4. SMT divergence"
    label.new(bar_index, high, lbl, color=color.new(#1a1a2e, 30),
     style=label.style_label_lower_left, textcolor=color.white, size=size.normal)

// ─── Alerts ──────────────────────────────────────────────────────────────────
alertcondition(bSMT, "Bullish SMT")
alertcondition(sSMT, "Bearish SMT")
alertcondition(bIFVG, "Bullish IFVG")
alertcondition(sIFVG, "Bearish IFVG")
