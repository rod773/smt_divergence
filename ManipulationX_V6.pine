//@version=5
indicator("ManipulationX V.6", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

grp_ent     = "══════ Entries ══════"
show_cont   = input.bool(true, "Continuations", group=grp_ent)
cont_text   = input.string("C", "Continuation Text", group=grp_ent)
show_rev    = input.bool(true, "Reversals", group=grp_ent)
rev_text    = input.string("R", "Reversal Text", group=grp_ent)

grp_kz      = "══════ Killzones ══════"
use_kz      = input.bool(false, "Use Killzones", group=grp_kz)
show_ny_kz  = input.bool(true, "New York KZ", group=grp_kz)
show_lon_kz = input.bool(true, "London KZ", group=grp_kz)

grp_ifvg    = "══════ IFVG ══════"
show_ifvg   = input.bool(true, "Show IFVGs", group=grp_ifvg)
ifvg_color1 = input.color(color.new(#333333, 0), "IFVG Color 1", group=grp_ifvg)
ifvg_color2 = input.color(color.new(#333333, 0), "IFVG Color 2", group=grp_ifvg)
ifvg_src    = input.string("Chart", "IFVG Source", options=["Chart", "1 min", "3 min", "5 min"], group=grp_ifvg)
ifvg_style_str = input.string("Solid", "IFVG Line Style", options=["Solid", "Dashed", "Dotted"], group=grp_ifvg)
ifvg_width  = input.int(1, "IFVG Line Width", minval=1, maxval=5, group=grp_ifvg)
min_size    = input.int(1, "Minimum Size", group=grp_ifvg)
size_filter = input.bool(true, "Size Filter", group=grp_ifvg)

grp_fvg     = "══════ HTF FVG ══════"
show_fvg_1h = input.bool(true, "Show Internal Liquidity (FVG)", group=grp_fvg)
fvg_1h_tf   = input.string("1 hour", "FVG Timeframe 1", options=["15 min", "30 min", "1 hour", "4 hour"], group=grp_fvg)
show_text_1h = input.bool(true, "Show Text", group=grp_fvg)
extend_fvg_1h = input.bool(false, "Extend FVG", group=grp_fvg)
max_fvg_1h  = input.int(3, "Max FVGs", minval=1, maxval=20, group=grp_fvg)

show_fvg_15m = input.bool(true, "Show Internal Liquidity (FVG)", group=grp_fvg)
fvg_15m_tf  = input.string("15 min", "FVG Timeframe 2", options=["5 min", "15 min", "30 min"], group=grp_fvg)
show_text_15m = input.bool(true, "Show Text", group=grp_fvg)
extend_fvg_15m = input.bool(false, "Extend FVG", group=grp_fvg)
max_fvg_15m = input.int(6, "Max FVGs", minval=1, maxval=20, group=grp_fvg)

grp_smt     = "══════ SMT Divergence ══════"
show_smt    = input.bool(true, "Show SMT", group=grp_smt)
smt_len     = input.int(3, "Swing Lookback", minval=2, maxval=10, group=grp_smt)

grp_liq     = "══════ Liquidity ══════"
show_liq    = input.bool(true, "Show Liquidity", group=grp_liq)

// ══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

get_tf(str) =>
    str == "1 min" ? "1" : str == "3 min" ? "3" : str == "5 min" ? "5" : str == "15 min" ? "15" : str == "30 min" ? "30" : str == "1 hour" ? "60" : str == "4 hour" ? "240" : "60"

get_ls(str) =>
    str == "Dashed" ? line.style_dashed : str == "Dotted" ? line.style_dotted : line.style_solid

// ══════════════════════════════════════════════════════════════════════════════
// FVG DETECTION
// ══════════════════════════════════════════════════════════════════════════════

tf1 = get_tf(fvg_1h_tf)
tf2 = get_tf(fvg_15m_tf)

// 1H FVG
o1_2 = request.security(syminfo.tickerid, tf1, open[2])
h1_2 = request.security(syminfo.tickerid, tf1, high[2])
l1_0 = request.security(syminfo.tickerid, tf1, low[0])
c1_1 = request.security(syminfo.tickerid, tf1, close[1])
o1_1 = request.security(syminfo.tickerid, tf1, open[1])
h1_0 = request.security(syminfo.tickerid, tf1, high[0])
l1_2 = request.security(syminfo.tickerid, tf1, low[2])

fvg1_bull = c1_1 > o1_1 and l1_0 > h1_2
fvg1_bear = c1_1 < o1_1 and h1_0 < l1_2

// 15M FVG
o2_2 = request.security(syminfo.tickerid, tf2, open[2])
h2_2 = request.security(syminfo.tickerid, tf2, high[2])
l2_0 = request.security(syminfo.tickerid, tf2, low[0])
c2_1 = request.security(syminfo.tickerid, tf2, close[1])
o2_1 = request.security(syminfo.tickerid, tf2, open[1])
h2_0 = request.security(syminfo.tickerid, tf2, high[0])
l2_2 = request.security(syminfo.tickerid, tf2, low[2])

fvg2_bull = c2_1 > o2_1 and l2_0 > h2_2
fvg2_bear = c2_1 < o2_1 and h2_0 < l2_2

// ══════════════════════════════════════════════════════════════════════════════
// IFVG DETECTION
// ══════════════════════════════════════════════════════════════════════════════

itf = get_tf(ifvg_src)
if itf == "60"
    itf := timeframe.period

io1 = request.security(syminfo.tickerid, itf, open[1])
ih0 = request.security(syminfo.tickerid, itf, high[0])
il0 = request.security(syminfo.tickerid, itf, low[0])
ic  = request.security(syminfo.tickerid, itf, close)
ic1 = request.security(syminfo.tickerid, itf, close[1])

ifvg_bull = show_ifvg and ic1 < io1 and ic > ih0
ifvg_bear = show_ifvg and ic1 > io1 and ic < il0

// ══════════════════════════════════════════════════════════════════════════════
// SMT DIVERGENCE
// ══════════════════════════════════════════════════════════════════════════════

ph = ta.pivothigh(high, smt_len, smt_len)
pl_s = ta.pivotlow(low, smt_len, smt_len)

ph_es = request.security("CME_MINI:ES1!", timeframe.period, ta.pivothigh(high, smt_len, smt_len))
pl_es = request.security("CME_MINI:ES1!", timeframe.period, ta.pivotlow(low, smt_len, smt_len))

var float pmph = na
var float pmpl = na
var float peph = na
var float pepl = na

if not na(ph)
    pmph := ph
if not na(pl_s)
    pmpl := pl_s
if not na(ph_es)
    peph := ph_es
if not na(pl_es)
    pepl := pl_es

smt_bull = show_smt and not na(pl_s) and not na(pl_es) and not na(pmpl) and not na(pepl) and pl_s > pmpl and pl_es < pepl
smt_bear = show_smt and not na(ph) and not na(ph_es) and not na(pmph) and not na(peph) and ph < pmph and ph_es > peph

// ══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY DETECTION
// ══════════════════════════════════════════════════════════════════════════════

swing_hi = ta.pivothigh(high, 5, 5)
swing_lo = ta.pivotlow(low, 5, 5)

var float lsh = na
var float lsh2 = na
var float lsl = na
var float lsl2 = na

if not na(swing_hi)
    lsh2 := lsh
    lsh := swing_hi

if not na(swing_lo)
    lsl2 := lsl
    lsl := swing_lo

eq_h = show_liq and not na(lsh) and not na(lsh2) and math.abs(lsh - lsh2) / lsh < 0.001
eq_l = show_liq and not na(lsl) and not na(lsl2) and math.abs(lsl - lsl2) / lsl < 0.001

// ══════════════════════════════════════════════════════════════════════════════
// KILLZONES
// ══════════════════════════════════════════════════════════════════════════════

is_ny = use_kz and show_ny_kz and not na(time(timeframe.period, "0930-1100", "America/New_York"))
is_lon = use_kz and show_lon_kz and not na(time(timeframe.period, "0230-0400", "America/New_York"))

bgcolor(is_ny ? color.new(color.yellow, 92) : na)
bgcolor(is_lon ? color.new(color.blue, 92) : na)

// ══════════════════════════════════════════════════════════════════════════════
// PLOTTING
// ══════════════════════════════════════════════════════════════════════════════

ls = get_ls(ifvg_style_str)

// ── FVG Boxes (1H) - Extend to right edge ──
var int fvg1_count = 0
if fvg1_bull and fvg1_count < max_fvg_1h
    box.new(bar_index - 2, l1_0, bar_index + 100, h1_2, bgcolor=color.new(#b0b0b0, 25), border_color=color.new(#b0b0b0, 40), border_width=1, extend=extend.right)
    fvg1_count += 1
if fvg1_bear and fvg1_count < max_fvg_1h
    box.new(bar_index - 2, h1_0, bar_index + 100, l1_2, bgcolor=color.new(#b0b0b0, 25), border_color=color.new(#b0b0b0, 40), border_width=1, extend=extend.right)
    fvg1_count += 1

// ── FVG Boxes (15M) - Extend to right edge ──
var int fvg2_count = 0
if fvg2_bull and fvg2_count < max_fvg_15m
    box.new(bar_index - 2, l2_0, bar_index + 100, h2_2, bgcolor=color.new(#b0b0b0, 35), border_color=color.new(#b0b0b0, 50), border_width=1, extend=extend.right)
    fvg2_count += 1
if fvg2_bear and fvg2_count < max_fvg_15m
    box.new(bar_index - 2, h2_0, bar_index + 100, l2_2, bgcolor=color.new(#b0b0b0, 35), border_color=color.new(#b0b0b0, 50), border_width=1, extend=extend.right)
    fvg2_count += 1

// ── FVG Labels (at right edge) ──
if fvg1_bull and show_text_1h
    label.new(bar_index + 5, (l1_0 + h1_2) / 2, "1H FVG", style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(#888888, 0), size=size.tiny, xloc=xloc.bar_index)
if fvg1_bear and show_text_1h
    label.new(bar_index + 5, (h1_0 + l1_2) / 2, "1H FVG", style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(#888888, 0), size=size.tiny, xloc=xloc.bar_index)

if fvg2_bull and show_text_15m
    label.new(bar_index + 5, (l2_0 + h2_2) / 2, "15M FVG", style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(#888888, 0), size=size.tiny, xloc=xloc.bar_index)
if fvg2_bear and show_text_15m
    label.new(bar_index + 5, (h2_0 + l2_2) / 2, "15M FVG", style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(#888888, 0), size=size.tiny, xloc=xloc.bar_index)

// ── IFVG Lines ──
if ifvg_bull
    line.new(bar_index - 2, il0, bar_index + 10, il0, color=ifvg_color1, style=ls, width=ifvg_width)

if ifvg_bear
    line.new(bar_index - 2, ih0, bar_index + 10, ih0, color=ifvg_color2, style=ls, width=ifvg_width)

// ── IFVG Box (small zone) ──
if ifvg_bull
    box.new(bar_index - 1, ic, bar_index + 3, il0, bgcolor=color.new(#999999, 60), border_color=color.new(#999999, 80))
if ifvg_bear
    box.new(bar_index - 1, ih0, bar_index + 3, ic, bgcolor=color.new(#999999, 60), border_color=color.new(#999999, 80))

// ── IFVG Labels ──
if ifvg_bull
    label.new(bar_index, il0, "IFVG", style=label.style_label_left, color=color.new(color.green, 30), textcolor=color.white, size=size.tiny)
if ifvg_bear
    label.new(bar_index, ih0, "IFVG", style=label.style_label_left, color=color.new(color.red, 30), textcolor=color.white, size=size.tiny)

// ── SMT Labels ──
if smt_bull
    label.new(bar_index, low - ta.atr(14) * 0.5, "SMT", style=label.style_label_up, color=color.new(color.green, 30), textcolor=color.white, size=size.tiny)
if smt_bear
    label.new(bar_index, high + ta.atr(14) * 0.5, "SMT", style=label.style_label_down, color=color.new(color.red, 30), textcolor=color.white, size=size.tiny)

// ── Entry Markers (colored squares) ──
var int trend = 0
if close > open
    trend := 1
else if close < open
    trend := -1

cont_long  = trend == 1 and close > open and close[1] > open[1]
cont_short = trend == -1 and close < open and close[1] < open[1]
rev_long  = close > open and close[1] < open[1] and close > high[1]
rev_short = close < open and close[1] > open[1] and close < low[1]

if show_cont and cont_long
    label.new(bar_index, low - ta.atr(14) * 0.3, cont_text, style=label.style_label_up, color=color.new(#000000, 0), textcolor=color.white, size=size.tiny)
if show_cont and cont_short
    label.new(bar_index, high + ta.atr(14) * 0.3, cont_text, style=label.style_label_down, color=color.new(#000000, 0), textcolor=color.white, size=size.tiny)

if show_rev and rev_long
    label.new(bar_index, low - ta.atr(14) * 0.5, rev_text, style=label.style_label_up, color=color.new(#00E676, 0), textcolor=color.white, size=size.tiny)
if show_rev and rev_short
    label.new(bar_index, high + ta.atr(14) * 0.5, rev_text, style=label.style_label_down, color=color.new(#FF1744, 0), textcolor=color.white, size=size.tiny)

// ── Liquidity Lines & $$$ ──
if eq_h
    line.new(bar_index - 20, lsh, bar_index + 5, lsh, color=color.gray, style=line.style_dashed, width=1)
    label.new(bar_index + 3, lsh, "$$$", style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.gray, size=size.tiny)

if eq_l
    line.new(bar_index - 20, lsl, bar_index + 5, lsl, color=color.gray, style=line.style_dashed, width=1)
    label.new(bar_index + 3, lsl, "$$$", style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.gray, size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(ifvg_bull, "IFVG Bullish", "Bullish IFVG")
alertcondition(ifvg_bear, "IFVG Bearish", "Bearish IFVG")
alertcondition(smt_bull, "SMT Bullish", "Bullish SMT")
alertcondition(smt_bear, "SMT Bearish", "Bearish SMT")
