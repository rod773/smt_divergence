//@version=5
indicator("SMT + FVG + Liquidity Sweep", overlay=true, max_boxes_count=500, max_lines_count=500)

// ══════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════

// ── SMT ──
grp_smt    = "══════ SMT Divergence ══════"
smt_on     = input.bool(true, "Show SMT", group=grp_smt)
smt_len    = input.int(5, "Swing lookback", minval=2, maxval=20, group=grp_smt)
smt_hi_col = input.color(color.new(#f44336, 20), "Bearish SMT", group=grp_smt)
smt_lo_col = input.color(color.new(#4CAF50, 20), "Bullish SMT", group=grp_smt)

// ── FVG HTF ──
grp_fvg    = "══════ Fair Value Gaps ══════"
fvg_on     = input.bool(true, "Show FVG", group=grp_fvg)
fvg_htf    = input.timeframe("60", "HTF", group=grp_fvg)
fvg_bull_c = input.color(color.new(#4CAF50, 80), "Bullish FVG", group=grp_fvg)
fvg_bear_c = input.color(color.new(#f44336, 80), "Bearish FVG", group=grp_fvg)

// ── Liquidity Sweep ──
grp_liq    = "══════ Liquidity Sweep ══════"
liq_on     = input.bool(true, "Show Sweeps", group=grp_liq)
liq_ref    = input.string("Previous Session", "Reference", options=["Previous Session", "Asia", "London"], group=grp_liq)
liq_bull_c = input.color(color.new(#00E676, 20), "Bull Sweep", group=grp_liq)
liq_bear_c = input.color(color.new(#E040FB, 20), "Bear Sweep", group=grp_liq)

// ── Sessions ──
grp_sess   = "══════ Sessions ══════"
sess_on    = input.bool(true, "Show Sessions", group=grp_sess)
show_asia  = input.bool(true, "Asia", group=grp_sess)
show_lon   = input.bool(true, "London", group=grp_sess)
show_ny    = input.bool(true, "New York", group=grp_sess)

// ══════════════════════════════════════════════════════════════════════
// SESSION TRACKING
// ══════════════════════════════════════════════════════════════════════

// UTC times: Asia 20-00, London 07-10, NY 13:30-20
is_asia   = not na(time(timeframe.period, "2000-0000", "UTC"))
is_london = not na(time(timeframe.period, "0700-1000", "UTC"))
is_ny     = not na(time(timeframe.period, "1330-2000", "UTC"))

var float a_hi = na, var float a_lo = na
var float l_hi = na, var float l_lo = na
var float n_hi = na, var float n_lo = na

var float pa_hi = na, var float pa_lo = na
var float pl_hi = na, var float pl_lo = na
var float pn_hi = na, var float pn_lo = na

// Update current session range
if is_asia
    a_hi := na(a_hi) ? high : math.max(a_hi, high)
    a_lo := na(a_lo) ? low  : math.min(a_lo, low)

if is_london
    l_hi := na(l_hi) ? high : math.max(l_hi, high)
    l_lo := na(l_lo) ? low  : math.min(l_lo, low)

if is_ny
    n_hi := na(n_hi) ? high : math.max(n_hi, high)
    n_lo := na(n_lo) ? low  : math.min(n_lo, low)

// New day → save previous sessions
new_day = ta.change(time("D")) != 0
if new_day
    pa_hi := a_hi, pa_lo := a_lo
    pl_hi := l_hi, pl_lo := l_lo
    pn_hi := n_hi, pn_lo := n_lo
    a_hi := na, a_lo := na
    l_hi := na, l_lo := na
    n_hi := na, n_lo := na

// ══════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP
// ══════════════════════════════════════════════════════════════════════

var float ref_hi = na
var float ref_lo = na

if liq_ref == "Asia"
    ref_hi := pa_hi
    ref_lo := pa_lo
else if liq_ref == "London"
    ref_hi := pl_hi
    ref_lo := pl_lo
else
    ref_hi := pa_hi
    ref_lo := pa_lo

// Sweep = wick beyond level, close back inside
swp_hi = liq_on and not na(ref_hi) and high > ref_hi and close < ref_hi
swp_lo = liq_on and not na(ref_lo) and low  < ref_lo and close > ref_lo

// ══════════════════════════════════════════════════════════════════════
// SMT DIVERGENCE (using built-in ES as MES proxy)
// ══════════════════════════════════════════════════════════════════════

// Swing highs/lows on current chart
ph = ta.pivothigh(high, smt_len, smt_len)
pl = ta.pivotlow(low,  smt_len, smt_len)

// Swing highs/lows on ES (proxy for MES)
ph_es = request.security("CME_MINI:ES1!", timeframe.period, ta.pivothigh(high, smt_len, smt_len))
pl_es = request.security("CME_MINI:ES1!", timeframe.period, ta.pivotlow(low,  smt_len, smt_len))

// SMT Bullish: MNQ makes lower low, ES makes higher low
smt_bull = smt_on and not na(pl) and not na(pl_es) and pl < pl[1] and pl_es > pl_es[1]

// SMT Bearish: MNQ makes higher high, ES makes lower high
smt_bear = smt_on and not na(ph) and not na(ph_es) and ph > ph[1] and ph_es < ph_es[1]

// ══════════════════════════════════════════════════════════════════════
// FVG (Higher Timeframe)
// ══════════════════════════════════════════════════════════════════════

// 3-candle FVG pattern on HTF
o2 = request.security(syminfo.tickerid, fvg_htf, open[2])
h2 = request.security(syminfo.tickerid, fvg_htf, high[2])
l0 = request.security(syminfo.tickerid, fvg_htf, low[0])
c1 = request.security(syminfo.tickerid, fvg_htf, close[1])
o1 = request.security(syminfo.tickerid, fvg_htf, open[1])
h0 = request.security(syminfo.tickerid, fvg_htf, high[0])
l2 = request.security(syminfo.tickerid, fvg_htf, low[2])

// Bullish FVG: big green candle [1], gap between candle[2] high and candle[0] low
fvg_bull = fvg_on and c1 > o1 and l0 > h2
// Bearish FVG: big red candle [1], gap between candle[0] high and candle[2] low
fvg_bear = fvg_on and c1 < o1 and h0 < l2

var box fvg_box = na
var label fvg_lbl = na

if fvg_bull
    fvg_box := box.new(bar_index - 2, l0, bar_index, h2, bgcolor=fvg_bull_c, border_color=color.new(color.green, 60))
if fvg_bear
    fvg_box := box.new(bar_index - 2, h0, bar_index, l2, bgcolor=fvg_bear_c, border_color=color.new(color.red, 60))

// ══════════════════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════════════════

// Session lines
plot(sess_on and show_asia ? pa_hi : na, "Asia High", color.new(color.orange, 40), 1, plot.style_linebr)
plot(sess_on and show_asia ? pa_lo : na, "Asia Low",  color.new(color.orange, 40), 1, plot.style_linebr)
plot(sess_on and show_lon  ? pl_hi : na, "Lon High",  color.new(color.blue, 40),   1, plot.style_linebr)
plot(sess_on and show_lon  ? pl_lo : na, "Lon Low",   color.new(color.blue, 40),   1, plot.style_linebr)
plot(sess_on and show_ny   ? pn_hi : na, "NY High",   color.new(color.yellow, 40), 2, plot.style_linebr)
plot(sess_on and show_ny   ? pn_lo : na, "NY Low",    color.new(color.yellow, 40), 2, plot.style_linebr)

// Liquidity sweep markers
plotshape(swp_hi, "Sweep↑", shape.triangledown, location.abovebar, liq_bear_c, size=size.small, text="SWP")
plotshape(swp_lo, "Sweep↓", shape.triangleup,   location.belowbar, liq_bull_c, size=size.small, text="SWP")

// SMT markers
plotshape(smt_bear, "SMT↓", shape.xcross, location.abovebar, smt_hi_col, size=size.tiny, text="SMT")
plotshape(smt_bull, "SMT↑", shape.xcross, location.belowbar, smt_lo_col, size=size.tiny, text="SMT")

// ══════════════════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════════════════

alertcondition(swp_hi,    "Liq Sweep High", "🔴 Liquidity Sweep HIGH")
alertcondition(swp_lo,    "Liq Sweep Low",  "🟢 Liquidity Sweep LOW")
alertcondition(smt_bear,  "SMT Bearish",    "🔴 SMT Bearish Divergence")
alertcondition(smt_bull,  "SMT Bullish",    "🟢 SMT Bullish Divergence")
alertcondition(fvg_bull,  "Bull FVG",       "🟢 Bullish FVG")
alertcondition(fvg_bear,  "Bear FVG",       "🔴 Bearish FVG")

// ══════════════════════════════════════════════════════════════════════
// INFO TABLE
// ══════════════════════════════════════════════════════════════════════

var t = table.new(position.top_right, 2, 6, bgcolor=color.new(#1e1e1e, 10), border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(t, 0, 0, "SMT",     text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, smt_on ? "ON" : "OFF", text_color=smt_on ? color.green : color.gray, text_size=size.small)
    table.cell(t, 0, 1, "FVG HTF", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, fvg_on ? fvg_htf : "OFF", text_color=fvg_on ? color.green : color.gray, text_size=size.small)
    table.cell(t, 0, 2, "LiQ Ref", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, liq_on ? liq_ref : "OFF", text_color=liq_on ? color.green : color.gray, text_size=size.small)
    table.cell(t, 0, 3, "Asia",    text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, show_asia ? str.tostring(pa_hi,"#.##")+" / "+str.tostring(pa_lo,"#.##") : "-", text_color=color.orange, text_size=size.small)
    table.cell(t, 0, 4, "London",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, show_lon ? str.tostring(pl_hi,"#.##")+" / "+str.tostring(pl_lo,"#.##") : "-", text_color=color.blue, text_size=size.small)
    table.cell(t, 0, 5, "NY",      text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, show_ny ? str.tostring(pn_hi,"#.##")+" / "+str.tostring(pn_lo,"#.##") : "-", text_color=color.yellow, text_size=size.small)
